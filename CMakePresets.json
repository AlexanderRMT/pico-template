{
  "version": 3,
  "cmakeMinimumRequired": { "major": 3, "minor": 21, "patch": 0 },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceParentDir}/../build/${sourceDirName}-${presetName}",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "pico",
      "inherits": "base",
      "displayName": "Pico (RP2040)",
      "cacheVariables": { "PICO_BOARD": "pico" }
    },
    {
      "name": "pico_w",
      "inherits": "base",
      "displayName": "Pico W",
      "cacheVariables": { "PICO_BOARD": "pico_w" }
    },
    {
      "name": "pico2",
      "inherits": "base",
      "displayName": "Pico 2 (RP2350)",
      "cacheVariables": { "PICO_BOARD": "pico2" }
    },
    {
      "name": "yd_rp2040",
      "inherits": "base",
      "displayName": "YD-RP2040 (16MB)",
      "cacheVariables": { "PICO_BOARD": "yd_rp2040" }
    },

    {
      "name": "waveshare_zero",
      "inherits": "base",
      "displayName": "Waveshare RP2040-Zero (no SWD)",
      "cacheVariables": { "PICO_BOARD": "waveshare_rp2040_zero" }
    }
  ]
}